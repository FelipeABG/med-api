datasource db {
  provider = "postgresql"
  url = env("DB_URL")
}

generator client {
  provider     = "prisma-client"           
  // The usual way generates commonJS module, which deno does not understand
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  hash String
}
